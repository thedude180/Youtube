# ─── Core ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/creatoros

# Public-facing URL of the app (used for OAuth callback URLs)
# Dev:  http://localhost:5000
# Prod: https://yourdomain.com
APP_URL=http://localhost:5000

PORT=5000
NODE_ENV=development

# Long random string — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-in-production

# ─── AI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google / YouTube OAuth ──────────────────────────────────────────────────
# Console: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: ${APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# One price ID per tier (create in Stripe dashboard)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_EMPIRE=price_...

# ─── Platform OAuth ──────────────────────────────────────────────────────────
# Twitch — redirect URI: ${APP_URL}/api/channels/oauth/twitch/callback
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Discord — redirect URI: ${APP_URL}/api/channels/oauth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# TikTok — redirect URI: ${APP_URL}/api/channels/oauth/tiktok/callback
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# Kick — redirect URI: ${APP_URL}/api/channels/oauth/kick/callback
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
KICK_STREAM_URL=
