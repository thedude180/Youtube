# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/creatoros
PGDATABASE=creatoros
PGHOST=localhost
PGPORT=5432
PGUSER=user
PGPASSWORD=password

# ─── App ──────────────────────────────────────────────────────────────────────
# The public URL of this server — used for OAuth redirect URIs and email links.
# In Replit this is derived from REPLIT_DEV_DOMAIN / REPLIT_DEPLOYMENT automatically.
# Outside Replit, set this explicitly:
APP_URL=http://localhost:5000
SESSION_SECRET=change-me-to-a-long-random-string
NODE_ENV=development

# ─── AI ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ─── Google / YouTube OAuth ──────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add redirect URI: ${APP_URL}/api/youtube/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Gmail (for digest emails) ───────────────────────────────────────────────
# On Replit: handled automatically via Replit connector proxy (no extra setup).
# Outside Replit: provide a Gmail OAuth refresh token directly.
# See: https://developers.google.com/gmail/api/quickstart/nodejs
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_FROM_ADDRESS=your-gmail-address@gmail.com

# ─── Stripe ──────────────────────────────────────────────────────────────────
# On Replit: handled automatically via Replit connector proxy (no extra setup).
# Outside Replit: provide Stripe keys directly.
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key

# ─── Twitch ──────────────────────────────────────────────────────────────────
TWITCH_DEV_CLIENT_ID=your-twitch-client-id
TWITCH_DEV_CLIENT_SECRET=your-twitch-client-secret

# ─── Discord ─────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_ID=your-discord-channel-id

# ─── TikTok ──────────────────────────────────────────────────────────────────
TIKTOK_DEV_CLIENT_ID=your-tiktok-client-id
TIKTOK_DEV_CLIENT_SECRET=your-tiktok-client-secret

# ─── X / Twitter ─────────────────────────────────────────────────────────────
TWITTER_DEV_CLIENT_ID=your-twitter-client-id
TWITTER_DEV_CLIENT_SECRET=your-twitter-client-secret
TWITTER_DEV_API_KEY=your-twitter-api-key
TWITTER_DEV_API_KEY_SECRET=your-twitter-api-key-secret
TWITTER_DEV_ACCESS_TOKEN=your-twitter-access-token
TWITTER_DEV_ACCESS_TOKEN_SECRET=your-twitter-access-token-secret
X_DEV_ACCESS_TOKEN=your-x-access-token
X_DEV_REFRESH_TOKEN=your-x-refresh-token

# ─── Kick ────────────────────────────────────────────────────────────────────
KICK_DEV_CLIENT_ID=your-kick-client-id
KICK_DEV_CLIENT_SECRET=your-kick-client-secret
KICK_STREAM_URL=rtmps://your-kick-ingest-url/app

# ─── Replit-specific (leave blank outside Replit) ───────────────────────────
# These are injected automatically when running inside Replit.
# The app falls back to APP_URL when these are absent.
# REPLIT_DEPLOYMENT=
# REPLIT_DEV_DOMAIN=
# REPLIT_CONNECTORS_HOSTNAME=   ← Replit connector proxy (Gmail + Stripe on Replit)
# REPL_IDENTITY=                ← Replit auth token
# WEB_REPL_RENEWAL=             ← Replit deploy auth token
