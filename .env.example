# ─── Core ─────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/creatoros

# Public-facing URL (used for OAuth callback construction)
# Dev: http://localhost:5000  |  Prod: https://yourdomain.com
APP_URL=http://localhost:5000

PORT=5000
NODE_ENV=development

# Long random string — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-in-production

# ─── AI ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google / YouTube OAuth ───────────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials
# Scopes: youtube.readonly, youtube.upload, youtube.force-ssl
# Redirect URI: ${APP_URL}/api/channels/oauth/youtube/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_EMPIRE=price_...

# ─── Social / Growth Platforms ────────────────────────────────────────────────
# All redirect URIs follow pattern: ${APP_URL}/api/channels/oauth/{platform}/callback

# Discord — discord.com/developers/applications
# Add DISCORD_BOT_TOKEN for bot-API fallback posting (no webhook needed)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# TikTok — developers.tiktok.com → Login Kit + Content Posting API
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# Twitter / X — developer.twitter.com → OAuth 2.0 + tweet.write scope
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Instagram — developers.facebook.com → instagram_basic + instagram_content_publish
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# Reddit — reddit.com/prefs/apps → script/web app, submit scope
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Facebook — developers.facebook.com → pages_manage_posts scope
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ─── Live Streaming Destinations ──────────────────────────────────────────────
# Twitch — dev.twitch.tv → channel:manage:broadcast scope
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Kick — kick.com/settings/developer
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
KICK_STREAM_URL=
