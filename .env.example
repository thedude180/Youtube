# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/creatoros
PGDATABASE=creatoros
PGHOST=localhost
PGPORT=5432
PGUSER=user
PGPASSWORD=password

# ─── App ──────────────────────────────────────────────────────────────────────
# The public URL of this server — used for OAuth redirect URIs and email links.
# On Replit this is derived from REPLIT_DEV_DOMAIN / REPLIT_DEPLOYMENT automatically.
# Outside Replit (Docker, Render, bare VM) set this explicitly, e.g.:
#   APP_URL=https://your-domain.com
APP_URL=http://localhost:5000
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars
NODE_ENV=development

# ─── AI ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Google / YouTube OAuth ──────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add redirect URI: ${APP_URL}/api/youtube/callback
# Add redirect URI: ${APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: override the YouTube OAuth redirect URI explicitly
# GOOGLE_REDIRECT_URI=

# ─── Gmail (for digest emails) ───────────────────────────────────────────────
# On Replit: handled automatically via Replit connector proxy — no extra setup.
# Outside Replit: provide a Gmail OAuth refresh token from the same Google Cloud
# project as GOOGLE_CLIENT_ID/SECRET.
# See: https://developers.google.com/gmail/api/quickstart/nodejs
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_FROM_ADDRESS=

# ─── Stripe ──────────────────────────────────────────────────────────────────
# On Replit: handled automatically via Replit connector proxy — no extra setup.
# Outside Replit: provide Stripe keys directly.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Twitch ──────────────────────────────────────────────────────────────────
TWITCH_DEV_CLIENT_ID=
TWITCH_DEV_CLIENT_SECRET=

# ─── Discord ─────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# ─── TikTok ──────────────────────────────────────────────────────────────────
TIKTOK_DEV_CLIENT_ID=
TIKTOK_DEV_CLIENT_SECRET=

# ─── X / Twitter ─────────────────────────────────────────────────────────────
TWITTER_DEV_CLIENT_ID=
TWITTER_DEV_CLIENT_SECRET=
TWITTER_DEV_API_KEY=
TWITTER_DEV_API_KEY_SECRET=
TWITTER_DEV_ACCESS_TOKEN=
TWITTER_DEV_ACCESS_TOKEN_SECRET=
X_DEV_ACCESS_TOKEN=
X_DEV_REFRESH_TOKEN=

# ─── Kick ────────────────────────────────────────────────────────────────────
KICK_DEV_CLIENT_ID=
KICK_DEV_CLIENT_SECRET=
KICK_STREAM_URL=

# ─── Object Storage (S3-compatible) ─────────────────────────────────────────
# Optional. When all four S3_* vars below are set the app stores vault files,
# clips, and reels in S3-compatible object storage (Cloudflare R2, AWS S3,
# MinIO, Backblaze B2, etc.) instead of the local filesystem.
# Leave blank to use local disk (default — fine for single-server deployments).
#
# Cloudflare R2 example:
#   S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   S3_ACCESS_KEY_ID=<R2 API token ID>
#   S3_SECRET_ACCESS_KEY=<R2 API token secret>
#   S3_BUCKET=creatoros-vault
#   S3_REGION=auto
#   S3_PUBLIC_URL=https://pub-<hash>.r2.dev   # optional public CDN URL
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=auto
S3_PUBLIC_URL=

# ─── Replit-specific (injected automatically inside Replit — leave blank) ────
# The app detects these and falls back gracefully to APP_URL when absent.
# REPLIT_DEPLOYMENT=
# REPLIT_DEV_DOMAIN=
# REPLIT_CONNECTORS_HOSTNAME=
# REPL_IDENTITY=
# WEB_REPL_RENEWAL=
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=
# PRIVATE_OBJECT_DIR=
# PUBLIC_OBJECT_SEARCH_PATHS=
