# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/creatoros
PGDATABASE=creatoros
PGHOST=localhost
PGPORT=5432
PGUSER=user
PGPASSWORD=password

# Session
SESSION_SECRET=your-session-secret-here

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Google / YouTube OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Twitch
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret
TWITCH_STREAM_KEY=your-twitch-stream-key

# Discord
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_PUBLIC_KEY=your-discord-public-key
DISCORD_WEBHOOK_URL=your-discord-webhook-url

# TikTok
TIKTOK_CLIENT_ID=your-tiktok-client-id
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# X (Twitter)
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
X_API_KEY=your-x-api-key
X_API_KEY_SECRET=your-x-api-key-secret
X_BEARER_TOKEN=your-x-bearer-token

# Kick
KICK_CLIENT_ID=your-kick-client-id
KICK_CLIENT_SECRET=your-kick-client-secret
KICK_STREAM_KEY=your-kick-stream-key
KICK_STREAM_URL=your-kick-stream-url

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
